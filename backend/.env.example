# Copy to .env and fill in real values. Never commit .env.
MONGODB_URL=mongodb://127.0.0.1:27017
DATABASE_NAME=british_auction_rfq
JWT_SECRET=replace-with-a-long-random-string-not-change-me
APP_ENV=development
# Comma-separated origins; production should list exact origins only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional: restrict to one deployment, e.g. ^https://your-app\\.vercel\\.app$
CORS_ORIGIN_REGEX=
CORS_VERCEL_APP_URL=
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BID_SUBMIT_PER_MINUTE=10
